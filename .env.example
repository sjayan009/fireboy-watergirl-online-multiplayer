# Public URL of the always-on game host the Vercel frontend connects to.
# Hetzner VPS + DuckDNS (recommended):  wss://your-name.duckdns.org
# Cloudflare Tunnel:                    wss://game.YOURDOMAIN.com
# Fly.io:                               wss://fireboy-watergirl-game-host.fly.dev
# Local development:                    ws://127.0.0.1:8080
VITE_GAME_SERVER_URL=wss://your-name.duckdns.org

# --- VPS deploy only (docker-compose.yml, Option C) ---
# The public hostname Caddy gets a TLS cert for. Put this in a .env on the VPS.
# SITE_ADDRESS=your-name.duckdns.org
